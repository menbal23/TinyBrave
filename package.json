{
  "name": "tinybrave",
  "version": "0.1.0",
  "description": "TinyBrave — a retro pixel-style 2D turn-based RPG starter built with Phaser 3 and TypeScript",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"*.{ts,json,html}\""
  },
  "dependencies": {
    "phaser": "^3.60.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  }
}
